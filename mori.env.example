# ─────────────────────────────────────────────────────
# MORI — variables de entorno
# Copia a ~/.mori/.env y edita
# ─────────────────────────────────────────────────────

# Directorio base de Mori
MORI_HOME=${HOME}/.mori

# Base de datos
MORI_DB_PATH=${MORI_HOME}/data/mori.sqlite3

# Token de autenticación para la API y UI
# Genera uno con: openssl rand -hex 32
MORI_TOKEN=cambia_esto_por_un_token_seguro

# Dominio (para Caddy + Cloudflare tunnel, opcional)
# MORI_DOMAIN=tu-dominio.com
# MORI_CF_TOKEN=tu_cloudflare_tunnel_token

# API Keys — añade solo las de los proveedores que uses
ANTHROPIC_API_KEY=      # Claude Opus 4.6, Sonnet 4.6, Haiku 4.5
OPENAI_API_KEY=         # GPT-5.4, GPT-5.4-mini, GPT-5.4-nano
GOOGLE_API_KEY=         # Gemini 3.1 Pro, Gemini 3 Flash, Gemini 3.1 Flash-Lite
MISTRAL_API_KEY=        # Mistral Large, Mistral Nemo (opcional)

# Notificaciones (opcional)
# MORI_TELEGRAM_BOT_TOKEN=
# MORI_TELEGRAM_CHAT_ID=
# MORI_WEBHOOK_URL=
