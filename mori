#!/usr/bin/env bash
set -euo pipefail

MORI_HOME="${MORI_HOME:-$HOME/.mori}"
MORI_REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE="docker compose --env-file $MORI_HOME/.env -f $MORI_REPO/docker-compose.yml"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[mori]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[mori]${NC} $*"; }
log_error() { echo -e "${RED}[mori]${NC} $*" >&2; }

cmd_install() {
    log_info "Installing Mori..."
    
    # Create directories
    mkdir -p "$MORI_HOME"/{config,data,logs}
    
    # Copy example files if not exists
    if [[ ! -f "$MORI_HOME/.env" ]]; then
        cp "$MORI_REPO/mori.env.example" "$MORI_HOME/.env"
        log_warn "Edit $MORI_HOME/.env with your API keys and token"
    fi
    
    if [[ ! -f "$MORI_HOME/config/mori.yaml" ]]; then
        cp "$MORI_REPO/mori.yaml.example" "$MORI_HOME/config/mori.yaml"
        log_info "Config created at $MORI_HOME/config/mori.yaml"
    fi
    
    if [[ ! -f "$MORI_HOME/config/mcp-gateway.json" ]]; then
        cp "$MORI_REPO/mcp-gateway.json.example" "$MORI_HOME/config/mcp-gateway.json"
        log_info "MCP gateway config created at $MORI_HOME/config/mcp-gateway.json"
    fi
    
    # Generate token if missing
    if grep -q "cambia_esto" "$MORI_HOME/.env"; then
        TOKEN=$(openssl rand -hex 32)
        sed -i "s/cambia_esto_por_un_token_seguro/$TOKEN/" "$MORI_HOME/.env"
        log_info "Generated auth token: $TOKEN"
    fi
    
    log_info "Building Docker images..."
    $COMPOSE build
    
    log_info "Mori installed. Run: ./mori start"
}

cmd_setup() {
    echo ""
    echo -e "${BOLD}${BLUE}════════════════════════════════════════${NC}"
    echo -e "${BOLD}${BLUE}  MORI — Setup interactivo${NC}"
    echo -e "${BOLD}${BLUE}════════════════════════════════════════${NC}"
    echo ""

    # ── Selección de proveedores ──────────────────────────────────────
    echo -e "Mori puede usar los siguientes proveedores de modelos."
    echo -e "Selecciona los que quieras configurar:"
    echo ""
    echo -e "  ${CYAN}[1]${NC} Anthropic Claude 4.x  (Opus, Sonnet, Haiku)"
    echo -e "  ${CYAN}[2]${NC} OpenAI GPT-5.4        (flagship, mini, nano)"
    echo -e "  ${CYAN}[3]${NC} Google Gemini 3.x     (Pro, Flash, Flash-Lite)"
    echo -e "  ${CYAN}[4]${NC} Ollama                (modelos locales — Llama, Qwen)"
    echo -e "  ${CYAN}[5]${NC} Claude Code CLI       (suscripción Pro/Max, sin API key)"
    echo ""
    read -rp "Introduce los números separados por comas [1,2,3,4,5]: " providers_input
    echo ""

    # Normalizar entrada: aceptar espacios y comas
    providers_input="${providers_input//[[:space:]]/}"

    use_anthropic=false
    use_openai=false
    use_google=false
    use_ollama=false
    use_claude_cli=false

    IFS=',' read -ra selected <<< "$providers_input"
    for n in "${selected[@]}"; do
        case "$n" in
            1) use_anthropic=true ;;
            2) use_openai=true ;;
            3) use_google=true ;;
            4) use_ollama=true ;;
            5) use_claude_cli=true ;;
        esac
    done

    # ── Recogida de API keys ──────────────────────────────────────────
    anthropic_key=""
    openai_key=""
    google_key=""

    if $use_anthropic; then
        echo -e "${YELLOW}[Anthropic]${NC} API key (se guarda en ~/.mori/.env, input oculto):"
        read -rsp "→ " anthropic_key
        echo ""
        if [[ -z "$anthropic_key" ]]; then
            log_warn "API key vacía — puedes añadirla luego en $MORI_HOME/.env"
        fi
    fi

    if $use_openai; then
        echo -e "${YELLOW}[OpenAI]${NC} API key (se guarda en ~/.mori/.env, input oculto):"
        read -rsp "→ " openai_key
        echo ""
        if [[ -z "$openai_key" ]]; then
            log_warn "API key vacía — puedes añadirla luego en $MORI_HOME/.env"
        fi
    fi

    if $use_google; then
        echo -e "${YELLOW}[Google]${NC} API key (se guarda en ~/.mori/.env, input oculto):"
        read -rsp "→ " google_key
        echo ""
        if [[ -z "$google_key" ]]; then
            log_warn "API key vacía — puedes añadirla luego en $MORI_HOME/.env"
        fi
    fi

    # ── Smart Routing ─────────────────────────────────────────────────
    echo ""
    read -rp "¿Activar Smart Routing? El router usará IA para decidir qué agente usar (requiere Google o OpenAI configurado). [s/N]: " smart_routing_input
    echo ""

    smart_routing=false
    routing_model="gemini-3-flash"

    if [[ "${smart_routing_input,,}" == "s" ]]; then
        smart_routing=true

        echo -e "¿Qué modelo usar para routing? (recomendado: gemini-3-flash por velocidad y coste)"
        echo -e "  ${CYAN}[1]${NC} gemini-3-flash (recomendado — \$0.30/1M tokens)"
        echo -e "  ${CYAN}[2]${NC} gpt-5-4-mini (\$0.40/1M tokens)"
        echo -e "  ${CYAN}[3]${NC} gemini-3-1-flash-lite (\$0.25/1M tokens — más barato)"
        read -rp "→ " routing_choice
        echo ""

        case "${routing_choice:-1}" in
            1) routing_model="gemini-3-flash" ;;
            2) routing_model="gpt-5-4-mini" ;;
            3) routing_model="gemini-3-1-flash-lite" ;;
            *) routing_model="gemini-3-flash" ;;
        esac
    fi

    # ── Verificar si ya existe config ─────────────────────────────────
    mkdir -p "$MORI_HOME"/{config,data,logs}

    if [[ -f "$MORI_HOME/config/mori.yaml" ]]; then
        read -rp "Ya existe una configuración. ¿Sobreescribir? [s/N]: " overwrite_input
        echo ""
        if [[ "${overwrite_input,,}" != "s" ]]; then
            log_warn "Configuración no modificada."
            log_info "Puedes editar manualmente: $MORI_HOME/config/mori.yaml"
            return
        fi
    fi

    # ── Determinar modelos por agente según proveedores seleccionados ──
    # coder
    if $use_anthropic; then
        coder_model="claude-sonnet-4-6"
    elif $use_openai; then
        coder_model="gpt-5-4"
    elif $use_ollama; then
        coder_model="qwen-coder-local"
    else
        coder_model="llama3-local"
    fi

    if $use_ollama; then
        coder_fallback="qwen-coder-local"
    elif $use_anthropic; then
        coder_fallback="claude-haiku-4-5"
    else
        coder_fallback=""
    fi

    # planner
    if $use_anthropic; then
        planner_model="claude-opus-4-6"
    elif $use_openai; then
        planner_model="gpt-5-4"
    elif $use_google; then
        planner_model="gemini-3-1-pro"
    else
        planner_model="llama3-local"
    fi

    # researcher
    if $use_openai; then
        researcher_model="gpt-5-4"
        researcher_fallback="gemini-3-flash"
    elif $use_google; then
        researcher_model="gemini-3-1-pro"
        researcher_fallback="gemini-3-flash"
    elif $use_anthropic; then
        researcher_model="claude-sonnet-4-6"
        researcher_fallback=""
    else
        researcher_model="llama3-local"
        researcher_fallback=""
    fi

    # writer
    if $use_google; then
        writer_model="gemini-3-flash"
        writer_fallback="llama3-local"
    elif $use_ollama; then
        writer_model="llama3-local"
        writer_fallback=""
    elif $use_anthropic; then
        writer_model="claude-haiku-4-5"
        writer_fallback=""
    elif $use_openai; then
        writer_model="gpt-5-4-mini"
        writer_fallback=""
    else
        writer_model="llama3-local"
        writer_fallback=""
    fi

    # reviewer
    if $use_ollama; then
        reviewer_model="llama3-local"
        if $use_anthropic; then
            reviewer_fallback="claude-sonnet-4-6"
        elif $use_openai; then
            reviewer_fallback="gpt-5-4-mini"
        else
            reviewer_fallback=""
        fi
    elif $use_anthropic; then
        reviewer_model="claude-haiku-4-5"
        reviewer_fallback=""
    elif $use_openai; then
        reviewer_model="gpt-5-4-mini"
        reviewer_fallback=""
    elif $use_google; then
        reviewer_model="gemini-3-flash"
        reviewer_fallback=""
    else
        reviewer_model="llama3-local"
        reviewer_fallback=""
    fi

    # orchestrator
    if $use_google; then
        orch_model="gemini-3-flash"
    elif $use_openai; then
        orch_model="gpt-5-4-mini"
    elif $use_anthropic; then
        orch_model="claude-haiku-4-5"
    else
        orch_model="llama3-local"
    fi

    # Smart routing: si se activó, usa el elegido; si no, mantiene orch_model
    if $smart_routing; then
        final_routing_model="$routing_model"
    else
        final_routing_model="$orch_model"
    fi

    smart_routing_yaml="false"
    $smart_routing && smart_routing_yaml="true"

    # ── Generar .env ──────────────────────────────────────────────────
    MORI_TOKEN=$(openssl rand -hex 32)

    cat > "$MORI_HOME/.env" << EOF
MORI_HOME=\${HOME}/.mori
MORI_DB_PATH=\${MORI_HOME}/data/mori.sqlite3
MORI_TOKEN=${MORI_TOKEN}
EOF

    if $use_anthropic; then
        echo "ANTHROPIC_API_KEY=${anthropic_key}" >> "$MORI_HOME/.env"
    fi
    if $use_openai; then
        echo "OPENAI_API_KEY=${openai_key}" >> "$MORI_HOME/.env"
    fi
    if $use_google; then
        echo "GOOGLE_API_KEY=${google_key}" >> "$MORI_HOME/.env"
    fi

    # ── Generar mori.yaml dinámico ────────────────────────────────────
    # Usamos 'YAML_EOF' con comillas para evitar expansión de variables bash
    {
    cat > "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'
# ─────────────────────────────────────────────────────
# MORI v2 — configuración generada por ./mori setup
# ─────────────────────────────────────────────────────
YAML_EOF

    # orchestrator section — necesita expansión de variables
    cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
orchestrator:
  poll_seconds: 15
  max_parallel_tasks: 4
  max_parallel_per_project: 2
  heartbeat_seconds: 30
  timeout_default_seconds: 1800
  retry_on_failure: 1
  stream_output: true
  smart_routing: ${smart_routing_yaml}
  routing_model: ${final_routing_model}

YAML_VARS

    # Sección de modelos — encabezado fijo
    cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'
# ─────────────────────────────────────────────────────
# MODELOS — solo los proveedores seleccionados
# ─────────────────────────────────────────────────────
models:
YAML_EOF
    } # end block

    # Modelos Anthropic
    if $use_anthropic; then
        cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'

  # ── Anthropic Claude 4.x ──────────────────────────
  - id: claude-opus-4-6
    provider: anthropic
    model: claude-opus-4-6
    api_key_env: ANTHROPIC_API_KEY
    max_tokens: 1000000
    capabilities: [reasoning, coding, writing, analysis, planning]
    cost_per_1k_input: 0.015
    cost_per_1k_output: 0.075
    supports_tools: true

  - id: claude-sonnet-4-6
    provider: anthropic
    model: claude-sonnet-4-6
    api_key_env: ANTHROPIC_API_KEY
    max_tokens: 1000000
    capabilities: [coding, writing, analysis, reasoning]
    cost_per_1k_input: 0.003
    cost_per_1k_output: 0.015
    supports_tools: true

  - id: claude-haiku-4-5
    provider: anthropic
    model: claude-haiku-4-5
    api_key_env: ANTHROPIC_API_KEY
    max_tokens: 200000
    capabilities: [writing, analysis, fast]
    cost_per_1k_input: 0.0008
    cost_per_1k_output: 0.004
    supports_tools: true
YAML_EOF
    fi

    # Modelos OpenAI
    if $use_openai; then
        cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'

  # ── OpenAI GPT-5.4 ────────────────────────────────
  - id: gpt-5-4
    provider: openai
    model: gpt-5.4
    api_key_env: OPENAI_API_KEY
    max_tokens: 200000
    capabilities: [reasoning, writing, analysis, vision, coding]
    cost_per_1k_input: 0.0025
    cost_per_1k_output: 0.015
    supports_tools: true

  - id: gpt-5-4-mini
    provider: openai
    model: gpt-5.4-mini
    api_key_env: OPENAI_API_KEY
    max_tokens: 200000
    capabilities: [writing, analysis, fast]
    cost_per_1k_input: 0.0004
    cost_per_1k_output: 0.0016
    supports_tools: true

  - id: gpt-5-4-nano
    provider: openai
    model: gpt-5.4-nano
    api_key_env: OPENAI_API_KEY
    max_tokens: 200000
    capabilities: [fast, writing]
    cost_per_1k_input: 0.00005
    cost_per_1k_output: 0.0004
    supports_tools: true
YAML_EOF
    fi

    # Modelos Google
    if $use_google; then
        cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'

  # ── Google Gemini 3.x ─────────────────────────────
  - id: gemini-3-1-pro
    provider: google
    model: gemini-3.1-pro-preview
    api_key_env: GOOGLE_API_KEY
    max_tokens: 1000000
    capabilities: [reasoning, writing, analysis, vision, coding]
    cost_per_1k_input: 0.003
    cost_per_1k_output: 0.015
    supports_tools: true

  - id: gemini-3-flash
    provider: google
    model: gemini-3-flash
    api_key_env: GOOGLE_API_KEY
    max_tokens: 1000000
    capabilities: [writing, analysis, fast, routing]
    cost_per_1k_input: 0.0003
    cost_per_1k_output: 0.0025
    supports_tools: true

  - id: gemini-3-1-flash-lite
    provider: google
    model: gemini-3.1-flash-lite-preview
    api_key_env: GOOGLE_API_KEY
    max_tokens: 1000000
    capabilities: [writing, fast]
    cost_per_1k_input: 0.00025
    cost_per_1k_output: 0.0015
    supports_tools: true
YAML_EOF
    fi

    # Modelos Ollama
    if $use_ollama; then
        cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'

  # ── Ollama (local) ────────────────────────────────
  - id: llama3-local
    provider: ollama
    model: llama3.3:70b
    base_url: http://ollama:11434
    capabilities: [writing, analysis, coding]
    cost_per_1k_input: 0
    cost_per_1k_output: 0
    supports_tools: false

  - id: qwen-coder-local
    provider: ollama
    model: qwen2.5-coder:32b
    base_url: http://ollama:11434
    capabilities: [coding]
    cost_per_1k_input: 0
    cost_per_1k_output: 0
    supports_tools: false
YAML_EOF
    fi

    # Modelo Claude CLI
    if $use_claude_cli; then
        cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'

  # Claude via suscripción Pro/Max (sin API key — usa OAuth del CLI)
  # Requiere: npm install -g @anthropic-ai/claude-code && claude auth login
  - id: claude-max
    provider: claude-cli
    model: claude-sonnet-4-6
    cli_path: claude
    capabilities: [coding, writing, analysis, reasoning, planning]
    cost_per_1k_input: 0
    cost_per_1k_output: 0
    supports_tools: false
    allowed_tools: [Read, Edit, Bash, WebSearch, ListDirectory]
    max_turns: 20
YAML_EOF
    fi

    # ── Sección agentes ───────────────────────────────────────────────
    cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'

# ─────────────────────────────────────────────────────
# AGENTES — roles y configuración
# ─────────────────────────────────────────────────────
agents:

YAML_EOF

    # Agente orchestrator (con variables)
    cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: orchestrator
    name: Orchestrator (Router)
    model: ${orch_model}
    role: router
    enabled: true
    system_prompt: |
      Eres el orquestador de Mori. Recibes una tarea y decides:
      1. Si puedes ejecutarla directamente o necesitas delegarla
      2. Qué agente o modelo es el más adecuado
      3. Si debe dividirse en subtareas
      Tienes acceso al catálogo de agentes y sus capacidades.
      Sé conciso en tu razonamiento. Prioriza el modelo más económico
      que pueda hacer el trabajo con calidad suficiente.
    tools:
      - task_list
      - task_create
      - task_update_status
      - note_list
      - pipeline_status

YAML_VARS

    # Agente coder
    if [[ -n "$coder_fallback" ]]; then
        cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: coder
    name: Code Agent
    model: ${coder_model}
    fallback_model: ${coder_fallback}
    role: executor
    enabled: true
YAML_VARS
    else
        cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: coder
    name: Code Agent
    model: ${coder_model}
    role: executor
    enabled: true
YAML_VARS
    fi

    cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'
    routing:
      tags: [coding, dev, bug, feature, refactor, test, deploy]
      areas: [proyecto, sistema]
      keywords: [código, script, función, clase, API, endpoint, test, implementar, arreglar]
    system_prompt: |
      Eres un ingeniero de software experto. Tu trabajo es implementar
      la tarea descrita con código limpio, testeado y documentado.
      Usa las herramientas de filesystem para leer el contexto del proyecto
      antes de hacer cambios. Verifica tu trabajo ejecutando tests si existen.
    tools:
      - read_file
      - write_file
      - list_directory
      - search_files
      - container_logs
      - container_restart
    working_directory: true
    timeout_seconds: 3600

YAML_EOF

    # Agente researcher
    if [[ -n "$researcher_fallback" ]]; then
        cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: researcher
    name: Research Agent
    model: ${researcher_model}
    fallback_model: ${researcher_fallback}
    role: executor
    enabled: true
YAML_VARS
    else
        cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: researcher
    name: Research Agent
    model: ${researcher_model}
    role: executor
    enabled: true
YAML_VARS
    fi

    cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'
    routing:
      tags: [research, análisis, revisión, comparativa, informe]
      areas: [personal, empresa]
      keywords: [investigar, analizar, comparar, resumir, buscar, informe]
    system_prompt: |
      Eres un analista de investigación. Tu trabajo es recopilar,
      analizar y sintetizar información de manera estructurada.
      Crea notas con los hallazgos para que queden en el sistema.
    tools:
      - web_search
      - note_list
      - note_create
      - decision_create
    timeout_seconds: 1200

YAML_EOF

    # Agente writer
    if [[ -n "$writer_fallback" ]]; then
        cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: writer
    name: Writer Agent
    model: ${writer_model}
    fallback_model: ${writer_fallback}
    role: executor
    enabled: true
YAML_VARS
    else
        cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: writer
    name: Writer Agent
    model: ${writer_model}
    role: executor
    enabled: true
YAML_VARS
    fi

    cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'
    routing:
      tags: [escritura, redacción, email, documento, post, blog]
      keywords: [escribir, redactar, documento, email, post]
    system_prompt: |
      Eres un escritor profesional. Produces contenido claro,
      bien estructurado y adaptado al tono requerido.
    tools:
      - note_create
      - note_list
    timeout_seconds: 600

YAML_EOF

    # Agente reviewer
    if [[ -n "$reviewer_fallback" ]]; then
        cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: reviewer
    name: Reviewer Agent
    model: ${reviewer_model}
    fallback_model: ${reviewer_fallback}
    role: reviewer
    enabled: true
YAML_VARS
    else
        cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: reviewer
    name: Reviewer Agent
    model: ${reviewer_model}
    role: reviewer
    enabled: true
YAML_VARS
    fi

    cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'
    system_prompt: |
      Eres un revisor crítico. Evalúa el trabajo producido por otro agente:
      - ¿Cumple con los requisitos de la tarea?
      - ¿Hay errores evidentes?
      - ¿Qué mejorarías?
      Sé conciso. Devuelve exactamente una de estas palabras al inicio:
      APROBADO, NECESITA_CAMBIOS, o RECHAZADO
      seguida de una explicación breve.
    tools: []
    timeout_seconds: 300

YAML_EOF

    # Agente planner
    cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  - id: planner
    name: Planner Agent
    model: ${planner_model}
    role: planner
    enabled: true
YAML_VARS

    cat >> "$MORI_HOME/config/mori.yaml" << 'YAML_EOF'
    system_prompt: |
      Recibes una tarea grande o ambigua y la divides en subtareas
      concretas y ejecutables. Cada subtarea debe ser independiente
      y asignable a un agente específico.
      Devuelve un JSON con el array de subtareas con esta estructura:
      {"subtasks": [{"title": "...", "description": "...", "tags": [...], "area": "..."}]}
    tools:
      - task_create
      - project_list
    timeout_seconds: 300

YAML_EOF

    # Agente claude-sub (solo si claude-cli seleccionado)
    if $use_claude_cli; then
        claude_sub_fallback=""
        if $use_ollama; then
            claude_sub_fallback="llama3-local"
        fi

        if [[ -n "$claude_sub_fallback" ]]; then
            cat >> "$MORI_HOME/config/mori.yaml" << YAML_VARS
  # Agente que usa suscripción Claude (sin coste API)
  - id: claude-sub
    name: Claude Subscription Agent
    model: claude-max
    fallback_model: ${claude_sub_fallback}
    role: executor
    enabled: false
YAML_VARS
